# Database (Neon pooled endpoint)
DATABASE_URL=postgresql://USER:PASSWORD@EP-XXXX-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# API Key (Vercel → backend 間認証、ローカル開発では空でスキップ)
API_KEY=

# LLM プロバイダ選択 ("gemini" | "openai" | "fallback")
LLM_PROVIDER=gemini

# Gemini (LLM_PROVIDER=gemini 時に使用)
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (LLM_PROVIDER=openai 時に使用)
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4.1-nano

# LLM共通
LLM_MAX_RETRIES=3
LLM_TIMEOUT=30

# Email
RESEND_API_KEY=<your-resend-api-key>
EMAIL_FROM=CloudNature <cloudnature@stage-site.net>
NOTIFY_EMAIL=info@cloudnature.jp

# Notion連携
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Google API共通（Cloud RunではADC、ローカルはサービスアカウントJSONパス）
GOOGLE_SERVICE_ACCOUNT_JSON=

# Search Console
GSC_SITE_URL=sc-domain:cloudnature.jp

# GA4
GA4_PROPERTY_ID=properties/XXXXXXXXX

# 週次レポート送信先
REPORT_EMAIL=

# App
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001
DATA_TTL_DAYS=31
