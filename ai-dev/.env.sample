# 本番orそれ以外 (development / staging / production)
NEXT_PUBLIC_ENV=development

# メール送信（本体 CloudNature コーポレートサイトと共通の値を設定する）
RESEND_API_KEY=
EMAIL_FROM=
NOTIFY_EMAIL=

# Notion保存（任意。未設定でもフォームは動作するが案件テーブルへの自動追加はスキップされる）
# 保存先: Notion「登壇・セミナー」ページ内の「案件テーブル」（無料相談の申し込みを自動追記）
NOTION_API_KEY=
NOTION_DATABASE_ID=

# アナリティクス（任意。GTM未設定時はGA4直接タグに切り替わる）
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity（任意）
NEXT_PUBLIC_CLARITY_ID=
